image Saloon_clash_4 = "Saloon_clash_4.png"
image Saloon_clash_5 = "Saloon_clash_5.png"
image Saloon_clash_6 = "Saloon_clash_6.png"
image Saloon_clash_finale = "Clash_finale.png"
