# Вы можете расположить сценарий своей игры в этом файле.

# Скрипт для звука
init python:
    def callback_bert(event, **kwargs):
        if event == "show":
            renpy.music.set_volume(0.4, delay=0, channel="sound")
            renpy.music.play("audio/beep1.wav", channel="sound", loop=True)
        elif event == "slow_done" or event == "end":
            renpy.music.stop(channel="sound")
    def callback_ann(event, **kwargs):
        if event == "show":
            renpy.music.set_volume(0.55, delay=0, channel="sound")
            renpy.music.play("audio/beep2.mp3", channel="sound", loop=True)
        elif event == "slow_done" or event == "end":
            renpy.music.stop(channel="sound")
    def callback_omy(event, **kwargs):
        if event == "show":
            renpy.music.set_volume(0.65, delay=0, channel="sound")
            renpy.music.play("audio/beep3.wav", channel="sound", loop=True)
        elif event == "slow_done" or event == "end":
            renpy.music.stop(channel="sound")

# Определение персонажей игры.
define b = Character('Берт', color="#ceb878", callback=callback_bert)
define a = Character('Энни', color="#83e645", callback=callback_ann)
define v = Character('Вилл Таун ст.', color="#ffde09")
define j = Character('Вилл Таун мл.', color="#374eff")
define o = Character('Ому Уни', color="#5cbe52", callback=callback_omy)
define nn = Character('Неизвестный голос', color="#ffffff")
define p1 = Character ("Преступник Побольше", color="#43cd7c")
define p2 = Character ("Преступник Посередине", color="#43cd7c")
define p3 = Character ("Преступник Поменьше", color="#43cd7c")


# Вместо использования оператора image можете просто
# складывать все ваши файлы изображений в папку images.
# Например, сцену bg room можно вызвать файлом "bg room.png",
# а eileen happy — "eileen happy.webp", и тогда они появятся в игре.

image Annie1 = "Ann_Act_1_1.png"
image Annie2 = "Ann_Act_1_2.png"
image Annie3 = "Act1_Ann_3.png"
image Act_2_saloon_Ann_serious = "Act_2_saloon_Ann_serious.png"
image Act_1_field_Ann_2 = "Act_1_field_Ann_2.png"
image Bert_to_city = "Bert_to_city.png"
image Bert_frustrated = "Bert_frustrated.png"
image Bert_saloon = "Saloon_Bert.png"
image Bert_traumatized = "Bert_traumatized.png"
image Bert_traumatized2 = "Bert_traumatized2.png"
image Steppe = "Steppe_Background.png"
image Black = "Black.png"
image Beginning_1 = "Beginning_1.png"
image Beginning_2 = "Beginning_2.png"
image Beginning_3 = "Beginning_3.png"
image Beginning_4 = "Beginning_4.png"
image Beginning_5 = "Beginning_5.png"
image Field = "Act_1_field.png"
image Field_leader = "Act_1_field_Leader_1.png"
image Field_bert = "Act_1_field_Bert.png"
image Field_Ann = "Act_1_field_Ann_1.png"
image Bert_horse = "Act_1_Bert_horse.png"
image Field_Ann_2 = "Act_1_field_Ann_3.png"
image City_back = "city_background.png"
image Saloon1 = "Saloon_1.png"
image Saloon_clash_1 = "Saloon_clash_1.png"
image Saloon_clash_2 = "Saloon_clash_2.png"
